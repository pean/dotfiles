{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.env.local)",
      "Read(**/.env.development)",
      "Read(**/.env.production)",
      "Read(**/.env.test)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Read(**/*.secrets)",
      "Read(**/.secrets/**)",
      "Read(**/.aws/credentials)",
      "Read(**/.ssh/id_*)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/*token*)",
      "Read(**/*.keystore)",
      "Read(**/*.jks)",
      "Read(**/secrets.yml)",
      "Read(**/secrets.yaml)",
      "Read(**/secrets.json)",
      "Read(**/credentials.json)",
      "Read(**/master.key)",
      "Read(**/config/credentials.yml.enc)",
      "Read(**/.git-credentials)",
      "Read(**/service-account*.json)",
      "Read(**/.docker/config.json)",
      "Read(**/.kube/config)",
      "Read(**/*.tfvars)",
      "Read(**/*.tfstate)",
      "Read(**/*.tfstate.backup)",
      "Read(**/.azure/credentials)",
      "Read(**/.pgpass)",
      "Read(**/.my.cnf)",
      "Read(**/.mylogin.cnf)",
      "Read(**/database.yml)",
      "Read(**/*password*)",
      "Read(**/*.private)",
      "Read(**/.htpasswd)",
      "Read(**/*.ovpn)",
      "Read(**/.zsh_history)",
      "Read(**/.bash_history)",
      "Read(**/*.asc)",
      "Read(**/.gnupg/**)",
      "Read(**/*.env.backup)",
      "Read(**/*.key.bak)",
      "Read(**/*secret*.bak)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm * -rf)",
      "Bash(rm * -fr)",
      "Edit(**/.env*)",
      "Edit(**/*secret*)",
      "Edit(**/*credential*)",
      "Edit(**/*token*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/.git-credentials)",
      "Edit(**/service-account*.json)",
      "Edit(**/.docker/config.json)",
      "Edit(**/.kube/config)",
      "Edit(**/*.tfvars)",
      "Edit(**/*.tfstate)",
      "Edit(**/.pgpass)",
      "Edit(**/.my.cnf)",
      "Edit(**/.mylogin.cnf)",
      "Edit(**/database.yml)",
      "Edit(**/*password*)",
      "Edit(**/*.private)",
      "Edit(**/.htpasswd)",
      "Edit(**/*.ovpn)",
      "Edit(**/.gnupg/**)",
      "Write(**/.env*)",
      "Write(**/*secret*)",
      "Write(**/*credential*)",
      "Write(**/*token*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/.git-credentials)",
      "Write(**/service-account*.json)",
      "Write(**/.docker/config.json)",
      "Write(**/.kube/config)",
      "Write(**/*.tfvars)",
      "Write(**/*.tfstate)",
      "Write(**/.pgpass)",
      "Write(**/.my.cnf)",
      "Write(**/.mylogin.cnf)",
      "Write(**/database.yml)",
      "Write(**/*password*)",
      "Write(**/*.private)",
      "Write(**/.htpasswd)",
      "Write(**/*.ovpn)",
      "Write(**/.gnupg/**)"
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "theme": "dark-daltonized",
  "editorMode": "vim",
  "autoCompactEnabled": true,
  "mcp": {
    "servers": {
      "getdreams-internal": {
        "type": "remote",
        "url": "https://internal.mcp.getdreams.com/mcp"
      },
      "getdreams-dev": {
        "type": "remote",
        "url": "https://dev.mcp.getdreams.com/mcp"
      },
      "getdreams-coms": {
        "type": "remote",
        "url": "https://coms.mcp.getdreams.com/mcp"
      },
      "getdreams-local": {
        "type": "remote",
        "url": "http://localhost:8787/mcp"
      },
      "linear": {
        "type": "remote",
        "url": "https://mcp.linear.app/sse"
      },
      "figma": {
        "type": "remote",
        "url": "https://mcp.figma.com/mcp"
      },
      "launchdarkly": {
        "type": "remote",
        "url": "https://mcp.launchdarkly.com/mcp/fm"
      },
      "sentry": {
        "type": "remote",
        "url": "https://mcp.sentry.dev/mcp"
      },
      "webflow": {
        "type": "remote",
        "url": "https://mcp.webflow.com/mcp"
      }
    }
  }
}
